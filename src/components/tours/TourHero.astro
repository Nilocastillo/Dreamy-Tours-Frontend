---
import type { Tour } from "@/interface/tours";
import type { Lang } from "@/lib/i18n";

interface Props {
  tour: Tour;
  lang: Lang;
}

const { tour } = Astro.props;
if (!tour) return;

const strapiUrl = import.meta.env.VITE_STRAPI_URL?.replace(/\/$/, "");
const heroImage = tour.imagenDestacada?.url
  ? `${strapiUrl}${tour.imagenDestacada.url}`
  : null;
---

<section
  class="tour-hero relative w-full h-[45vh] md:h-[50vh] lg:h-[55vh] overflow-hidden rounded-2xl md:rounded-3xl"
>
  {
    heroImage && (
      <img
        src={heroImage}
        alt={tour.imagenDestacada?.alternativeText ?? tour.titulo}
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
      />
    )
  }

  <div
    class="absolute inset-0 bg-linear-to-t from-black/80 via-black/40 to-transparent"
  >
  </div>

  <div
    class="tour-hero__content absolute bottom-0 left-0 right-0 z-10 px-6 md:px-10 lg:px-14 pb-8 md:pb-10 lg:pb-12"
  >
    <h1 class="tour-hero__title text-white font-bold drop-shadow-lg">
      {tour.titulo}
    </h1>
  </div>
</section>

<section class="tour-description w-full py-8 md:py-10">
  <div class="tour-description__content w-full">
    <p class="tour-description__text text-gray-700 leading-relaxed">
      {tour.content}
    </p>
  </div>
</section>
<style>
  .tour-hero__title {
    font-size: clamp(1.75rem, 5vw, 3rem);
  }
  .tour-description__text {
    font-size: clamp(0.9rem, 1.3vw, 1.1rem);
  }

  /* ── Animaciones de entrada ── */
  .tour-hero__title,
  .tour-description__text {
    animation: tour-fade-up 0.7s ease-out both;
  }
  .tour-hero__title {
    animation-delay: 0.12s;
  }
  .tour-description__text {
    animation-delay: 0.24s;
  }

  @keyframes tour-fade-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
