---
import type { Tour } from "@/interface/tours";
import type { Lang } from "@/lib/i18n";

interface Props {
  tour: Tour;
  lang: Lang;
}

const { tour, lang } = Astro.props;

if (!tour) return null;

const strapiUrl = import.meta.env.VITE_STRAPI_URL?.replace(/\/$/, "");

const mainImage = tour.imagenDestacada?.url
  ? `${strapiUrl}${tour.imagenDestacada.url}`
  : null;
---

<article
  class="group relative flex flex-col bg-white rounded-[2rem] overflow-hidden shadow-xl shadow-primary/5 border border-gray-100/50 hover:shadow-2xl hover:shadow-primary/10 transition-all duration-500 hover:-translate-y-2"
>
  {/* Image Container */}
  <a
    href={`/${lang}/${tour.slug}`}
    tabindex="-1"
    aria-hidden="true"
    class="relative w-full aspect-4/3 overflow-hidden block"
  >
    {
      mainImage ? (
        <img
          src={mainImage}
          alt={tour.imagenDestacada?.alternativeText ?? tour.titulo}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full bg-gray-200 flex items-center justify-center text-gray-400">
          No Image
        </div>
      )
    }
    <div
      class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-300"
    >
    </div>
  </a>

  {/* Content Container */}
  <div
    class="relative flex flex-col grow p-6 md:p-8 bg-white z-10 -mt-6 rounded-t-[2rem] transition-transform duration-300"
  >
    <h3
      class="text-xl md:text-2xl font-medium text-gray-900 mb-4 line-clamp-2 leading-tight group-hover:text-primary transition-colors"
    >
      <a href={`/${lang}/${tour.slug}`} class="focus:outline-hidden">
        {tour.titulo}
      </a>
    </h3>

    {/* Badges */}
    {
      tour.badge && tour.badge.length > 0 && (
        <div class="flex flex-wrap gap-3 mb-6">
          {tour.badge.slice(0, 5).map((b) => (
            <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-gray-50 border border-secondary/20 shadow-xs hover:border-secondary/50 transition-colors">
              {b.icono?.url && (
                <div class="flex-shrink-0 w-6 h-6 flex items-center justify-center bg-white rounded-md shadow-xs">
                  <img
                    src={`${strapiUrl}${b.icono.url}`}
                    alt={b.titulo}
                    class="w-4 h-4 object-contain"
                  />
                </div>
              )}
              <div class="flex flex-col min-w-0">
                <span class="text-[0.65rem] font-semibold uppercase tracking-wider text-gray-400 leading-none mb-0.5">
                  {b.titulo}
                </span>
                <span class="text-xs font-bold text-gray-800 leading-none truncate">
                  {b.content}
                </span>
              </div>
            </div>
          ))}
        </div>
      )
    }

    <div class="mt-auto pt-2">
      <a
        href={`/${lang}/${tour.slug}`}
        class="inline-flex items-center justify-center w-full px-6 py-3.5 rounded-xl border-2 border-primary text-primary bg-transparent font-semibold shadow-xs hover:bg-primary hover:text-white hover:shadow-lg hover:shadow-primary/30 active:scale-[0.98] transition-all duration-300 group/btn"
      >
        Ver Detalles
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5 ml-2 transform group-hover/btn:translate-x-1.5 transition-transform duration-300"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
    </div>
  </div>
</article>
